{
  "name": "tembro-cli-internal",
  "version": "3.1.4",
  "private": true,
  "description": "CLI for Tembro source-copy, presets, and theme setup.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "tembro": "dist/index.cjs"
  },
  "files": [
    "dist",
    "vendor",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node ../../scripts/sync-cli-assets.mjs && tsup",
    "clean": "node -e \"import('node:fs').then(fs => { fs.rmSync('dist', { recursive: true, force: true }); fs.rmSync('vendor', { recursive: true, force: true }); })\"",
    "prepack": "node ../../scripts/prepack-cli.mjs"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.5",
    "kolorist": "^1.8.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "~6.0.2"
  }
}
